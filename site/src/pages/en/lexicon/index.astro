---
import Base from '../../../layouts/Base.astro';
import { getStrings } from '../../../i18n';
const t = getStrings(Astro.currentLocale);
import { getLexicon, getAllEntityKeys } from '../../../lib/data';
import { glossary } from '../../../content-data/glossary.zh-Hant';

const lex = getLexicon();
const validKeys = new Set([...Object.keys(lex), ...getAllEntityKeys()]);
const entries = Object.entries(lex)
  .map(([key, e]) => ({ key, lemma: e.lemma, gloss: e.gloss, n: e.occurrences.length }))
  .sort((a, b) => a.key.localeCompare(b.key));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (p: string) => `${base}${p}` || '/';
const crumbs = [{ label: t.nav.lexicon }];
---

<Base title={t.lexicon.title} description={t.lexicon.desc} crumbs={crumbs}>
  <h1>{t.lexicon.title}</h1>

  <section class="glossary">
    <h2>教義要詞對照</h2>
    <p class="calm-note">核心要詞的本站標準譯法（防生成前後不一）；英文釋義與字根見各詞條（DPD）。</p>
    <ul class="gloss-list">
      {
        glossary.map((g) => (
          <li>
            {validKeys.has(g.key) ? (
              <a href={url(`/lexicon/${g.key}`)} class="gloss-term">
                <span lang="pi" class="gt-pali">{g.pali}</span>
                <span class="gt-zh">{g.zh}</span>
              </a>
            ) : (
              <span class="gloss-term">
                <span lang="pi" class="gt-pali nolink">{g.pali}</span>
                <span class="gt-zh">{g.zh}</span>
              </span>
            )}
            {g.en && <span class="gt-en calm-note" lang="en">{g.en}</span>}
            {g.note && <span class="gt-note calm-note">{g.note}</span>}
          </li>
        ))
      }
    </ul>
  </section>

  <h2 class="all-terms-h">全部原形</h2>
  <p class="calm-note">{entries.length} 個原形。輸入巴利字（變音可省略）即時篩選。</p>
  <input id="lex-filter" class="lex-filter" placeholder="dhamma / sati …" lang="pi" autocomplete="off" />
  <ul class="lex-list" id="lex-list">
    {
      entries.map((e) => (
        <li data-key={e.key}>
          <a href={url(`/lexicon/${e.key}`)}>
            <span class="ll-lemma" lang="pi">{e.lemma}</span>
            {e.gloss && <span class="ll-gloss" lang="en">{e.gloss.slice(0, 40)}</span>}
            <span class="ll-n calm-note">{e.n}</span>
          </a>
        </li>
      ))
    }
  </ul>
</Base>

<script is:inline>
  const inp = document.getElementById('lex-filter');
  const list = document.getElementById('lex-list');
  inp?.addEventListener('input', () => {
    const q = inp.value.trim().toLowerCase();
    for (const li of list.children) {
      const k = li.getAttribute('data-key') || '';
      li.style.display = !q || k.includes(q) ? '' : 'none';
    }
  });
</script>

<style>
  .glossary {
    margin: var(--space-4) 0 var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule);
  }
  .glossary h2,
  .all-terms-h {
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
  }
  .gloss-list {
    list-style: none;
    padding: 0;
    margin: var(--space-3) 0 0;
    display: grid;
    gap: var(--space-2);
  }
  .gloss-list li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2);
  }
  .gloss-term {
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .gt-pali {
    font-family: var(--font-pali);
    color: var(--thread);
  }
  .gt-pali.nolink {
    color: var(--ink);
  }
  .gt-zh {
    color: var(--ink);
    font-weight: 600;
  }
  .gt-en {
    font-size: var(--text-2xs);
  }
  .gt-note {
    font-size: var(--text-2xs);
    flex-basis: 100%;
  }
  .lex-filter {
    width: 100%;
    font-size: var(--text-sm);
    padding: var(--space-3);
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--ink);
    margin: var(--space-3) 0;
  }
  .lex-filter:focus-visible {
    border-color: var(--thread);
  }
  .lex-list {
    list-style: none;
    padding: 0;
    margin: 0;
    columns: 2;
    column-gap: var(--space-6);
  }
  .lex-list li {
    break-inside: avoid;
  }
  .lex-list a {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    padding: var(--space-1) 0;
    text-decoration: none;
  }
  .ll-lemma {
    font-family: var(--font-pali);
    color: var(--ink);
  }
  .ll-gloss {
    font-size: var(--text-2xs);
    color: var(--ink-soft);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ll-n {
    font-size: var(--text-2xs);
  }
  @media (max-width: 640px) {
    .lex-list {
      columns: 1;
    }
  }
</style>
