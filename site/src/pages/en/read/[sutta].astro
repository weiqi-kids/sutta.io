---
import Base from '../../../layouts/Base.astro';
import StudyPage from '../../../components/study/StudyPage';
import { getStrings } from '../../../i18n';
const t = getStrings(Astro.currentLocale);
import { listSuttas, getSutta, isPreviewSutta, getSuttaContext, getEntitiesForSutta } from '../../../lib/data';

export function getStaticPaths() {
  const suttas = listSuttas();
  return suttas.map((s, i) => ({
    params: { sutta: s.id },
    props: {
      prevId: i > 0 ? suttas[i - 1].id : null,
      nextId: i < suttas.length - 1 ? suttas[i + 1].id : null,
    },
  }));
}

const { sutta: suttaId } = Astro.params;
const { prevId, nextId } = Astro.props as { prevId: string | null; nextId: string | null };
const fixture = getSutta(suttaId!);

if (!fixture) {
  return Astro.redirect('/404');
}

const preview = isPreviewSutta(fixture);
const context = getSuttaContext(suttaId!);
const entities = getEntitiesForSutta(suttaId!);
const l3Api = (import.meta.env.PUBLIC_L3_API ?? '').replace(/\/$/, '');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const crumbs = [
  { label: fixture.sutta.collection_zh ?? fixture.sutta.collection, href: `${base}/browse` },
  { label: fixture.sutta.title_zh },
];
---

<Base
  title={fixture.sutta.title_zh}
  description={`${fixture.sutta.title_pali}（${fixture.sutta.title_zh}）逐字巴利解析與漢譯對照`}
  crumbs={crumbs}
  preview={preview}
  wide={true}
>
  <StudyPage client:load fixture={fixture} prevId={prevId} nextId={nextId} baseUrl={base} context={context} entities={entities} l3Api={l3Api} lang={Astro.currentLocale} />
</Base>
