---
// Base.astro — 全站基底版面（SITE_IA §5 導覽 / §8 響應式 / DESIGN §5 chrome 退場）
import '@fontsource/gentium-plus/400.css';
import '@fontsource/gentium-plus/400-italic.css';
import '@fontsource/gentium-plus/700.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
// 漢字自架（G-2）：思源宋體(Noto Serif TC) 正典、Noto Sans TC chrome。unicode-range 子集，只載所需。
import '@fontsource/noto-serif-tc/400.css';
import '@fontsource/noto-serif-tc/600.css';
import '@fontsource/noto-sans-tc/400.css';
import '@fontsource/noto-sans-tc/600.css';
import '../styles/global.css';
import { getStrings, localeOf, altLocaleHref } from '../i18n';
const locale = localeOf(Astro.currentLocale);
const lang = locale;
const t = getStrings(locale);
const altHref = altLocaleHref(Astro.url.pathname, locale);
const altLabel = locale === 'en' ? '中' : 'EN';
// 分析 / 站長驗證（env 閘控；未設則不載入，預設零追蹤）
const ga4Id = import.meta.env.PUBLIC_GA4_ID ?? '';
const gscToken = import.meta.env.PUBLIC_GSC_VERIFICATION ?? '';
const canonical = new URL(Astro.url.pathname, 'https://sutta.io').href;

export interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  title?: string;
  description?: string;
  crumbs?: Crumb[];
  preview?: boolean;
  /** 研經頁等需要滿版互動時，main 不加 measure 限制 */
  wide?: boolean;
  /** 頁面專屬 JSON-LD（如首頁 FAQPage），附加於站點 schema 之後 */
  extraSchema?: object | object[];
  /** 內容單薄頁（如無用法摘要的字頁）設 noindex,follow，集中抓取預算到真內容頁 */
  noindex?: boolean;
}
const {
  title,
  description = t.site.description,
  crumbs = [],
  preview = false,
  wide = false,
  extraSchema,
  noindex = false,
} = Astro.props;
const buildDate = new Date().toISOString().slice(0, 10);
const fullTitle = title ? `${title}｜${t.site.name}` : t.site.seoTitle;
const ogTitle = title ? `${title}｜${t.site.name}` : t.site.ogTitle;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const lp = locale === 'en' ? '/en' : '';
const url = (p: string) => `${base}${lp}${p}` || '/';
// hreflang 互連（同頁的另一語系）
const zhHref = 'https://sutta.io' + Astro.url.pathname.replace(/^\/en(\/|$)/, '/');
const enHref = 'https://sutta.io' + (Astro.url.pathname.startsWith('/en') ? Astro.url.pathname : '/en' + (Astro.url.pathname === '/' ? '/' : Astro.url.pathname));
const ogImage = 'https://sutta.io/og.png';
// Schema.org（GEO：讓 AI 理解這是一個「系統/工具」實體）
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['WebSite', 'WebApplication'],
  name: t.site.schemaName,
  alternateName: ['原典研經庫', 'Canonical Text Study System'],
  url: 'https://sutta.io/',
  inLanguage: ['zh-Hant', 'en', 'pi'],
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Web',
  description: t.site.description,
  isAccessibleForFree: true,
  dateModified: buildDate,
  creator: {
    '@type': 'Organization',
    name: t.site.schemaName,
    alternateName: '原典研經庫',
    url: 'https://sutta.io/',
  },
  publisher: {
    '@type': 'Organization',
    name: t.site.schemaName,
    alternateName: '原典研經庫',
    url: 'https://sutta.io/',
  },
  about: [
    { '@type': 'Thing', name: 'Pāli Canon' },
    { '@type': 'Thing', name: '巴利三藏' },
    { '@type': 'Thing', name: 'Early Buddhist Texts' },
  ],
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://sutta.io/search?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
// BreadcrumbList（SEO rich result）：由 crumbs 衍生，首頁置首；末項（當前頁）無 item。
const breadcrumbSchema =
  crumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          {
            '@type': 'ListItem',
            position: 1,
            name: t.common.breadcrumbHome,
            item: new URL(url('/'), 'https://sutta.io').href,
          },
          ...crumbs.map((c, i) => ({
            '@type': 'ListItem',
            position: i + 2,
            name: c.label,
            ...(c.href ? { item: new URL(c.href, 'https://sutta.io').href } : {}),
          })),
        ],
      }
    : null;
---

<!doctype html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href={url('/favicon.svg')} type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh-Hant" href={zhHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={zhHref} />

    {/* Open Graph（分享卡片） */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t.site.name} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'zh_TW'} />
    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Schema.org JSON-LD（SEO + GEO：AI 理解為研經系統實體） */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    {breadcrumbSchema && <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />}
    {extraSchema && <script type="application/ld+json" is:inline set:html={JSON.stringify(extraSchema)} />}

    {gscToken && <meta name="google-site-verification" content={gscToken} />}
    {
      ga4Id && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
          <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ga4Id}');`} />
        </>
      )
    }
    <script is:inline>
      // 主題：尊重儲存值，否則跟系統。早載避免閃爍。
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var dark = saved ? saved === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    {preview && <div class="preview-banner">{t.common.previewBanner}</div>}

    <header class="site-header chrome">
      <div class="container header-inner">
        <a class="brand" href={url('/')}>
          <span class="brand-name">{t.site.name}</span>
        </a>
        <button id="nav-toggle" class="nav-toggle" type="button" aria-label="選單" aria-expanded="false">
          ☰
        </button>
        <nav class="site-nav" id="site-nav" aria-label="主導覽">
          <a href={url('/browse')}>{t.nav.browse}</a>
          <a href={url('/search')}>{t.nav.search}</a>
          <a href={url('/lexicon')}>{t.nav.lexicon}</a>
          <a href={url('/world')}>{t.nav.world}</a>
          <a href={url('/about')}>{t.nav.about}</a>
          <a class="lang-switch" href={altHref} hreflang={locale === 'en' ? 'zh-Hant' : 'en'}>{altLabel}</a>
          <button id="theme-toggle" type="button" title={t.nav.theme} aria-label={t.nav.theme}>
            ◑
          </button>
        </nav>
      </div>
    </header>

    {
      crumbs.length > 0 && (
        <nav class="breadcrumb chrome" aria-label="麵包屑">
          <div class="container">
            <a href={url('/')}>{t.common.breadcrumbHome}</a>
            {crumbs.map((c) => (
              <Fragment>
                <span class="sep">›</span>
                {c.href ? <a href={c.href}>{c.label}</a> : <span aria-current="page">{c.label}</span>}
              </Fragment>
            ))}
          </div>
        </nav>
      )
    }

    <main class={wide ? 'site-main wide' : 'site-main'}>
      {wide ? <slot /> : <div class="container"><div class="measure"><slot /></div></div>}
    </main>

    <footer class="site-footer chrome">
      <div class="container footer-inner">
        <div class="footer-brand">
          <span class="footer-name">{t.site.name}</span>
          <span class="footer-tagline">{t.site.tagline}</span>
        </div>
        <nav class="footer-links" aria-label="頁尾導覽">
          <a href={url('/browse')}>{t.nav.browse}</a>
          <a href={url('/search')}>{t.nav.search}</a>
          <a href={url('/lexicon')}>{t.nav.lexicon}</a>
          <a href={url('/world')}>{t.nav.world}</a>
          <a href={url('/about')}>{t.nav.about}</a>
          <a
            href="https://github.com/weiqi-kids/sutta.io/issues/new?labels=%E5%8B%98%E8%AA%A4&title=%5B%E5%8B%98%E8%AA%A4%5D%20"
            target="_blank"
            rel="noopener">{t.nav.errata}</a
          >
        </nav>
      </div>
      <div class="container footer-meta-row">
        <p class="footer-meta">{t.site.unofficial}・{t.footer.rights}</p>
        <p class="footer-meta footer-sources">{t.footer.sources}</p>
        <p class="footer-dedication">{t.footer.dedication}</p>
      </div>
    </footer>

    <script is:inline define:vars={{ }}>
      var btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.addEventListener('click', function () {
          var el = document.documentElement;
          var next = el.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          el.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
        });
      }
      var navBtn = document.getElementById('nav-toggle');
      var navEl = document.getElementById('site-nav');
      if (navBtn && navEl) {
        navBtn.addEventListener('click', function () {
          var open = navEl.classList.toggle('is-open');
          navBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
        navEl.addEventListener('click', function (e) {
          if (e.target && e.target.tagName === 'A') {
            navEl.classList.remove('is-open');
            navBtn.setAttribute('aria-expanded', 'false');
          }
        });
      }
    </script>

    <style>
      .site-header {
        background: var(--surface);
        border-bottom: 1px solid var(--rule);
        position: sticky;
        top: 0;
        z-index: 50;
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 56px;
      }
      .brand {
        text-decoration: none;
        font-weight: 600;
      }
      .brand-name {
        font-family: var(--font-zh);
        font-size: var(--text-base);
        color: var(--ink);
      }
      .site-nav {
        display: flex;
        align-items: center;
        gap: var(--space-4);
      }
      .site-nav a {
        text-decoration: none;
        color: var(--ink-soft);
        font-size: var(--text-xs);
      }
      .site-nav a:hover {
        color: var(--ink);
      }
      #theme-toggle {
        background: transparent;
        border: 1px solid var(--rule);
        border-radius: var(--radius);
        color: var(--ink-soft);
        cursor: pointer;
        width: 32px;
        height: 32px;
        line-height: 1;
      }
      .lang-switch {
        border: 1px solid var(--rule);
        border-radius: var(--radius);
        padding: 4px 8px;
        font-size: var(--text-2xs) !important;
        color: var(--ink-soft) !important;
      }
      .lang-switch:hover {
        border-color: var(--thread);
      }
      .nav-toggle {
        display: none;
        background: transparent;
        border: 1px solid var(--rule);
        border-radius: var(--radius);
        color: var(--ink);
        cursor: pointer;
        width: 36px;
        height: 32px;
        font-size: var(--text-sm);
        line-height: 1;
      }
      @media (max-width: 640px) {
        .nav-toggle {
          display: inline-block;
        }
        .site-nav {
          display: none;
          position: absolute;
          top: 56px;
          right: 0;
          left: 0;
          flex-direction: column;
          align-items: flex-start;
          gap: 0;
          background: var(--surface);
          border-bottom: 1px solid var(--rule);
          padding: var(--space-2) var(--space-6);
        }
        .site-nav.is-open {
          display: flex;
        }
        .site-nav a {
          padding: var(--space-3) 0;
          width: 100%;
          border-bottom: 1px solid var(--rule);
        }
      }
      .breadcrumb {
        background: var(--surface);
        border-bottom: 1px solid var(--rule);
        font-size: var(--text-xs);
        color: var(--ink-soft);
      }
      .breadcrumb .container {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        padding-top: var(--space-2);
        padding-bottom: var(--space-2);
      }
      .breadcrumb a {
        color: var(--ink-soft);
        text-decoration: none;
      }
      .breadcrumb a:hover {
        color: var(--ink);
      }
      .breadcrumb .sep {
        color: var(--rule);
      }
      .site-main {
        padding: var(--space-8) 0 var(--space-8);
        min-height: 60vh;
      }
      .site-main.wide {
        padding: 0;
      }
      .site-footer {
        border-top: 1px solid var(--rule);
        background: var(--surface);
        color: var(--ink-soft);
        font-size: var(--text-xs);
        padding: var(--space-8) 0 var(--space-6);
        margin-top: var(--space-8);
      }
      .footer-inner {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--space-6);
        flex-wrap: wrap;
        padding-bottom: var(--space-4);
        border-bottom: 1px solid var(--rule);
      }
      .footer-brand {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
      }
      .footer-name {
        font-family: var(--font-zh);
        font-size: var(--text-base);
        color: var(--ink);
        font-weight: 600;
      }
      .footer-tagline {
        color: var(--ink-soft);
      }
      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-4);
      }
      .footer-links a,
      .site-footer a {
        color: var(--ink-soft);
        text-decoration: none;
      }
      .footer-links a:hover,
      .site-footer a:hover {
        color: var(--thread);
      }
      .footer-meta-row {
        padding-top: var(--space-4);
      }
      .footer-meta {
        margin: 0 0 var(--space-1);
        color: var(--ink-soft);
      }
      .footer-sources {
        color: var(--ink-soft);
        opacity: 0.85;
      }
      .footer-dedication {
        margin: var(--space-3) 0 0;
        color: var(--margin);
        font-family: var(--font-zh);
        letter-spacing: 0.08em;
        opacity: 0.8;
      }
      @media (max-width: 640px) {
        .site-nav {
          gap: var(--space-3);
        }
        .site-nav a {
          font-size: var(--text-xs);
        }
      }
    </style>
  </body>
</html>
