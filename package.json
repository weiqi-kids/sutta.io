{
  "name": "tipitaka-lens",
  "version": "0.1.0",
  "private": true,
  "description": "三藏原文解析 — AI 輔助巴利研經工具 (sutta.io)",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -C site dev",
    "build:site": "pnpm -C site build",
    "preview": "pnpm -C site preview",
    "pipeline": "pnpm -C pipeline run all",
    "generate": "pnpm -C generation run all",
    "review": "pnpm -C generation run review",
    "test:contract": "tsx scripts/validate-contract.ts",
    "test:keyscan": "tsx scripts/scan-secrets.ts",
    "test:golden": "tsx scripts/validate-golden.ts",
    "build:golden": "tsx scripts/build-golden.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
